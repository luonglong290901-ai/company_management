# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*.pyc
*$py.class

# SQLite database
*.sqlite3

# Virtual environment
venv/
env/
ENV/
.venv/
.env/

# Environment variables
*.env
*.env.*

# System files
.DS_Store
Thumbs.db

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# VS Code settings
.vscode/

# Python tooling / test caches
