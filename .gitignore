.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Build / packaging artifacts
build/
dist/
*.egg-info/

# Static files (if built)
staticfiles/
static_root/

# Node modules (if using npm/yarn for static)
node_modules/

# Tailwind/TMP
*.tmp

